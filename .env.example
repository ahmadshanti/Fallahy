EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Set to "true" only in development to accept "0000" as OTP without sending SMS.
EXPO_PUBLIC_DEV_OTP_BYPASS=

# Dev mode: skip the real login flow.
#   EXPO_PUBLIC_DEV_MODE=true                 → show buyer/farmer picker on launch
#   EXPO_PUBLIC_DEV_AUTH_ROLE=buyer | farmer  → auto-login as that role
EXPO_PUBLIC_DEV_MODE=
EXPO_PUBLIC_DEV_AUTH_ROLE=

# Azure Speech (TTS). Free tier: 0.5M chars/month standard.
EXPO_PUBLIC_AZURE_SPEECH_KEY=
EXPO_PUBLIC_AZURE_SPEECH_REGION=

# ElevenLabs (alternate TTS).
EXPO_PUBLIC_ELEVENLABS_API_KEY=

# Replicate (image gen for adopted-tree visualizer).
EXPO_PUBLIC_REPLICATE_API_TOKEN=

# Rwan's AI & Data Service (services/ai-service).
# Local: http://localhost:8000  |  After Render deploy: your https URL
EXPO_PUBLIC_AI_SERVICE_URL=http://localhost:8000
